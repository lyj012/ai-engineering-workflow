# ============================================================
# 本地运行数据 / 客户代码副本 / diff / 测试日志 —— 绝不入库
# （桥接 deliver-from-plan 会把目标仓库复制进 evidence/deliveries/<ts>/sandbox/，
#   可能含客户源码/构建产物；plans/runs 是运行输出。一律不发布。）
# ============================================================
evidence/runs/
evidence/plans/
evidence/deliveries/
# 说明：evidence/ 下"策展"的方法论证据（00-03/评审报告/决策日志/遗留风险/research-raw 等
# 顶层 *.md、*.json）是有意保留发布的，不在忽略之列；仅忽略上面三个"动态运行目录"。

# ============================================================
# 个人 / 敏感 harness 配置（遵全局规则 15/9）
# ============================================================
.claude/settings.local.json
.claude/**/settings.local.json
**/memory/
*.log
# yml/yaml 配置默认不入库（全局规则 9）
*.yml
*.yaml
!.github/workflows/*.yml
!.github/workflows/*.yaml

# ============================================================
# 临时 / 系统
# ============================================================
.DS_Store
*.tmp
/tmp/
scratchpad/

# 注意（C8 边界）：本仓库的核心可复用资产 .claude/workflows、.claude/agents、
# .claude/skills 与 docs/、vendor/ 是"项目自有、对外发布"的内容，【不】忽略。
# CLAUDE.md 的发布与否见仓库 README 与 CLAUDE.md 顶部的"公开发布边界"说明。
