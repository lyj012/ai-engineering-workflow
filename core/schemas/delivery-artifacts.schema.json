{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "delivery-manifest — deliver-from-plan output contract (shared by Claude + Codex)",
  "type": "object",
  "required": [
    "schemaVersion", "workflow", "finalStatus", "gate", "scope",
    "filesChanged", "scopeViolations", "reviewVerdicts", "reviewComplete",
    "independentVerify", "diffApplyCheckPassed", "openItems", "multiAgent"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "workflow": { "type": "string" },
    "sourcePlan": { "type": "string" },
    "targetRepo": { "type": "string" },
    "finalStatus": {
      "type": "string",
      "enum": [
        "DELIVERED",
        "DELIVERED_WITH_OPEN_ITEMS",
        "BLOCKED",
        "FAILED",
        "BLOCKED_MULTI_AGENT_UNAVAILABLE",
        "BLOCKED_MULTI_AGENT_CONTRACT_VIOLATION",
        "BLOCKED_INCOMPLETE_MULTI_AGENT_EXECUTION",
        "BLOCKED_MISSING_INDEPENDENT_REVIEWER",
        "BLOCKED_MISSING_INDEPENDENT_VERIFIER"
      ]
    },
    "gate": {
      "type": "object",
      "required": ["finalStatus", "readinessForDev"],
      "properties": {
        "finalStatus": { "type": "string", "enum": ["PASS", "PARTIAL", "CONDITIONAL", "FAILED_WITH_FINDINGS", "FAILED", "NEEDS_CLARIFICATION"] },
        "readinessForDev": { "type": "string", "enum": ["ready", "needs-clarification", "blocked"] },
        "requirementGoal": { "type": "string" }
      }
    },
    "scope": {
      "type": "object",
      "required": ["scopeFiles"],
      "properties": {
        "scopeFiles": { "type": "array", "items": { "type": "string" } },
        "optionalScopeFiles": { "type": "array", "items": { "type": "string" } }
      }
    },
    "doneCommand": { "type": "string" },
    "doneTrustworthy": { "type": "boolean" },
    "implementPassed": { "type": "boolean" },
    "filesChanged": { "type": "array", "items": { "type": "string" } },
    "scopeViolations": { "type": "array", "items": { "type": "string" } },
    "reviewVerdicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lens", "verdict", "blocking"],
        "properties": {
          "lens": { "type": "string" },
          "verdict": { "type": "string", "enum": ["ok", "needs-work"] },
          "blocking": { "type": "boolean" }
        }
      }
    },
    "fixHistory": { "type": "array" },
    "reviewComplete": { "type": "boolean" },
    "independentVerify": {
      "type": "object",
      "required": ["donePassedVerified", "scopeCleanVerified"],
      "properties": {
        "donePassedVerified": { "type": "boolean" },
        "doneExitCodeVerified": { "type": "integer" },
        "redGreenVerified": { "type": "boolean" },
        "scopeCleanVerified": { "type": "boolean" },
        "testsIntact": { "type": "boolean" }
      }
    },
    "multiAgent": {
      "type": "object",
      "required": ["required", "preflightPassed", "executed", "fallbackUsed", "parentAgentImplemented", "roles"],
      "properties": {
        "required": { "type": "boolean" },
        "requiredStages": { "type": "array", "items": { "type": "string" } },
        "preflightPassed": { "type": "boolean" },
        "executed": { "type": "boolean" },
        "fallbackUsed": { "type": "boolean" },
        "parentAgentImplemented": { "type": "boolean" },
        "parentAgentImplementedBeforeImplementerSpawn": { "type": "boolean" },
        "parentAgentRanTestsWithoutVerifier": { "type": "boolean" },
        "spawnSupported": { "type": "boolean" },
        "agentsDiscoverable": { "type": "boolean" },
        "executionContext": {
          "type": "object",
          "required": ["workflowRoot", "projectRoot", "workspaceRoot", "taskArtifactRoot", "changedFiles", "workspaceBaseline"],
          "properties": {
            "workflowRoot": { "type": "string" },
            "projectRoot": { "type": "string" },
            "workspaceRoot": { "type": "string" },
            "taskArtifactRoot": { "type": "string" },
            "changedFiles": { "type": "array", "items": { "type": "string" } },
            "workspaceBaseline": {
              "type": "object",
              "required": ["branch", "head", "statusShort", "diffStat", "untrackedFiles"],
              "properties": {
                "branch": { "type": "string" },
                "head": { "type": "string" },
                "statusShort": { "type": "string" },
                "diffStat": { "type": "string" },
                "untrackedFiles": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },
        "workspaceBaseline": {
          "type": "object",
          "properties": {
            "preExistingStatusShort": { "type": "string" },
            "preExistingUntracked": { "type": "array", "items": { "type": "string" } },
            "preflightHead": { "type": "string" },
            "head": { "type": "string" }
          }
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["stage", "role", "codexAgent", "spawned", "completed", "resultValidated"],
            "properties": {
              "stage": { "type": "string", "enum": ["analysis", "requirement-analysis", "repository-analysis", "risk-analysis", "solution-design", "test-planning", "test-materialization", "implementation", "review", "fix", "verification", "browser-verification", "publish", "remote-publish-verification"] },
              "role": { "type": "string" },
              "codexAgent": { "type": "string", "pattern": "^aiew_[a-z0-9_]+$" },
              "spawned": { "type": "boolean" },
              "completed": { "type": "boolean" },
              "resultValidated": { "type": "boolean" },
              "threadId": {},
              "runtimeThreadId": {},
              "executionId": {},
              "unverified": { "type": "boolean" }
            }
          }
        }
      }
    },
    "diffApplyCheckPassed": { "type": "boolean" },
    "openItems": { "type": "array", "items": { "type": "string" } }
  }
}
