diff --git a/app.sh b/app.sh
index 20c27af..e44ffcb 100644
--- a/app.sh
+++ b/app.sh
@@ -5,8 +5,15 @@ case "${1:-}" in
   "")
     echo "Hello from minimal target"
     ;;
+  "--greet")
+    if [ -z "${2:-}" ]; then
+      echo "missing name" >&2
+      exit 2
+    fi
+    echo "Hello, $2!"
+    ;;
   "--help")
-    echo "Usage: ./app.sh [--help]"
+    echo "Usage: ./app.sh [--help] [--greet <name>]"
     ;;
   *)
     echo "unknown option: $1" >&2
diff --git a/test.sh b/test.sh
