diff --git a/examples/minimal-target/app.sh b/examples/minimal-target/app.sh
--- a/examples/minimal-target/app.sh
+++ b/examples/minimal-target/app.sh
@@ -3,6 +3,13 @@
 case "${1:-}" in
   "")
     echo "Hello from minimal target"
     ;;
+  "--greet")
+    if [ -z "${2:-}" ]; then
+      echo "missing name" >&2
+      exit 2
+    fi
+    echo "Hello, $2!"
+    ;;
   "--help")
-    echo "Usage: ./app.sh [--help]"
+    echo "Usage: ./app.sh [--help] [--greet <name>]"
     ;;
   *)
diff --git a/examples/minimal-target/test.sh b/examples/minimal-target/test.sh
--- a/examples/minimal-target/test.sh
+++ b/examples/minimal-target/test.sh
@@ -2,6 +2,9 @@
 set -euo pipefail
 
+greeting="$(bash ./app.sh --greet Alice)"
+test "$greeting" = "Hello, Alice!"
+
 out="$(bash ./app.sh)"
 test "$out" = "Hello from minimal target"
